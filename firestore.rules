rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Participants (phone-keyed) ──
    match /participants/{phone} {
      // Anyone can read public data (for "who is coming" list)
      // But phone numbers and tokens are stored — client should filter
      allow read: if true;

      // Anyone can create if doc ID matches the phone field
      // Token must be provided (generated client-side)
      allow create: if request.resource.data.phone == phone
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.token is string
                    && request.resource.data.token.size() > 0;

      // Update only if token matches existing document
      // Cannot change phone, token, or createdAt
      allow update: if request.resource.data.phone == phone
                    && request.resource.data.token == resource.data.token
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['phone', 'token', 'createdAt']);

      // No hard deletes
      allow delete: if false;
    }

    // ── Photos (user-uploaded after the event) ──
    // Closed friends-only event (WhatsApp-distributed URL). No Firebase Auth,
    // so we can't truly verify identity — but we DO cap document size, clamp
    // capturedAt to a sensible range, and validate every field, so a leaked
    // URL can at most cost moderate storage, not destroy the archive in
    // one curl loop.
    match /photos/{photoId} {
      allow read: if true;

      allow create: if request.resource.data.uploaderPhone is string
                    && request.resource.data.uploaderPhone.size() > 0
                    && request.resource.data.uploaderPhone.size() < 30
                    && request.resource.data.uploaderName is string
                    && request.resource.data.uploaderName.size() < 100
                    // `id` field must equal the document key — prevents a doc
                    // at photos/AAA with `id:'BBB'` that would make the UI's
                    // deletePhoto(rec.id) target a different (or non-existent)
                    // document while the original stays.
                    && request.resource.data.id == photoId
                    // URL must be a Cloudinary HTTPS asset on OUR cloud —
                    // refuses javascript:/data:/attacker.com tracking URLs.
                    && request.resource.data.url is string
                    && request.resource.data.url.size() > 0
                    && request.resource.data.url.size() < 500
                    && request.resource.data.url.matches('^https://res\\.cloudinary\\.com/dqznby5hm/.+')
                    && request.resource.data.capturedAt is number
                    && request.resource.data.capturedAt > 1700000000000     // > 2023-11
                    && request.resource.data.capturedAt < request.time.toMillis() + 86400000
                    && request.resource.data.kind in ['photo', 'video']
                    && request.resource.data.cloudinaryPublicId is string
                    && request.resource.data.cloudinaryPublicId.size() > 0
                    && request.resource.data.cloudinaryPublicId.size() < 200;

      allow update: if false;
      // Delete is wide-open by design: no Firebase Auth, closed-event app,
      // the UI gates own-vs-admin client-side only. ADMIN red ring in
      // gallery.js is NOT a security boundary — anyone with the site URL
      // can call db.deletePhoto(id) from DevTools. Risk accepted; if this
      // ever needs to be a real boundary, move delete behind a Cloud
      // Function that verifies the participant token.
      allow delete: if request.auth == null
                    && resource.data.uploaderPhone is string;
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
