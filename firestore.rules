rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helper ──
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'Arthur.komishenko@gmail.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Public aggregates (read-only, written by Cloud Functions) ──
    match /aggregates/public {
      allow read: if true;
      allow write: if false; // Only Cloud Functions
    }

    // ── Participants ──
    match /participants/{userId} {
      // Anyone can read public fields
      allow read: if true;

      // Only the owner can create/update their own document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        // Cannot change these fields
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['googleEmail', 'createdAt']);

      // Soft-delete only (set cancelled: true), no hard delete
      allow delete: if false;

      // ── Change log (admin read-only) ──
      match /changeLog/{entryId} {
        allow read: if isAdmin();
        allow write: if false; // Only Cloud Functions
      }
    }

    // ── Carpool requests ──
    match /carpoolRequests/{requestId} {
      // Requester or driver can read
      allow read: if isLoggedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toDriverId == request.auth.uid
            || isAdmin());

      // Any logged-in user can create a request
      allow create: if isLoggedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Driver can update status to accepted/declined
      allow update: if isLoggedIn()
        && resource.data.toDriverId == request.auth.uid
        && request.resource.data.status in ['accepted', 'declined']
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['fromUserId', 'toDriverId', 'createdAt']);

      allow delete: if false;
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
