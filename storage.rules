rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Photo and video uploads from participants — closed friends-only event.
    // Client strips EXIF (incl. GPS) and resizes before upload; we cap size
    // here as a final guard against rogue clients.
    match /photos/{filename} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024              // 15 MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;                                                  // client-side ownership
    }

    match /videos/{filename} {
      allow read: if true;
      allow write: if request.resource.size < 250 * 1024 * 1024             // 250 MB
                   && request.resource.contentType.matches('video/.*');
      allow delete: if true;
    }

    // Deny everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
